# ===== Docker Compose 环境变量模板 =====
# 用法：复制本文件为 .env 并填入真实值
#   cp .env.example .env
# .env 已被 .gitignore 忽略，不会进入仓库；本文件（.env.example）会随仓库发布。

# InfluxDB 3 Core 管理员令牌（必填，请务必替换为你自己的值）
# 获取方式二选一：
#   方式A（推荐，自己生成）：
#     apiv3_$(openssl rand -hex 16)
#   方式B（启动后从日志复制）：
#     先 docker compose up -d influxdb3 redis
#     再 docker compose logs influxdb3  → 复制控制台打印的 apiv3_... 令牌填此处
# 注：Explorer 会通过 DEFAULT_API_TOKEN 自动使用同一令牌，无需单独配置。
INFLUXDB3_AUTH_TOKEN=

# InfluxDB 节点 ID（用于原生/容器启动标识，可自定义）
NODE_ID=digital-twin-node-0

# Explorer 会话密钥（建议填，32 字节 hex；留空则使用容器默认值）
# 生成：openssl rand -hex 32
EXPLORER_SESSION_SECRET_KEY=

# 是否启用后端写库到 InfluxDB（可选，默认 false）
INFLUXDB_ENABLED=false
